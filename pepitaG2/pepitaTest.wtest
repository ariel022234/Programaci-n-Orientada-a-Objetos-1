import wollok.game.*
import aves.*
import direcciones.*

describe "Tests de Pepita" {

	method initialize() {
		// El game no se reinicia en cada test: https://github.com/uqbar-project/wollok/issues/1896
		game.clear()
		game.height(10) //configurar el tamaño es importante 
		game.width(10)

		pepita.position(game.at(5,5))
	}

	test "pepita mover arriba" {

		pepita.mover(arriba)
		assert.equals(game.at(5,6), pepita.position())
		assert.equals(89, pepita.energia())
	}

	test "pepita mover abajo" {

		pepita.mover(abajo)
		assert.equals(game.at(5,4), pepita.position())
		assert.equals(89, pepita.energia())
	}

	test "pepita mover izquierda" {

		pepita.mover(izquierda)
		assert.equals(game.at(4,5), pepita.position())
		assert.equals(89, pepita.energia())
	}

	test "pepita mover derecha" {

		pepita.mover(derecha)
		assert.equals(game.at(6,5), pepita.position())
		assert.equals(89, pepita.energia())
	}


	test "pepita no sale de la pantalla por arriba" {
		pepita.position(game.at(5,9))
		assert.throwsException({pepita.mover(arriba)})
		assert.equals(game.at(5,9), pepita.position())
		assert.equals(100, pepita.energia())
	}

	test "pepita no sale de la pantalla por abajo" {

		pepita.position(game.at(5,0))
		assert.throwsException({pepita.mover(abajo)})
		assert.equals(game.at(5,0), pepita.position())
		assert.equals(100, pepita.energia())
	}

	test "pepita no sale de la pantalla por izquierda" {

		pepita.position(game.at(0,5))
		assert.throwsException({pepita.mover(izquierda)})
		assert.equals(game.at(0,5), pepita.position())
		assert.equals(100, pepita.energia())
	}

	test "pepita no sale de la pantalla por derecha" {

		pepita.position(game.at(9,5))
		assert.throwsException({pepita.mover(derecha)})
		assert.equals(game.at(9,5), pepita.position())
		assert.equals(100, pepita.energia())
	}

}

